COMPOSE_PROJECT_NAME=blanksystem
GLOBAL_NETWORK=blanksystem
GROUP_ID=com.blanksystem

# Version of Postgres
POSTGRES_VERSION=18.0

# User for the 'Postgres'
POSTGRES_USER=sa

# Password for the 'sa' user
POSTGRES_PASS=sa

# Password for the 'Postgres' user
POSTGRES_DB=blank

# Port to expose Postgres to the host
POSTGRES_PORT=54322

# Increase or decrease based on the available host memory (in bytes)
POSTGRES_MEM_LIMIT=1073741824
POSTGRES_DB_MEM_LIMIT=1073741824

# https://docs.docker.com/compose/compose-file/compose-versioning/#upgrading

# Version of PGADMIN
PGADMIN_VERSION=9.8.0

# User for the 'PGADMIN'
PGADMIN_USER=blanksystem-db@db.com

# Password for the 'PGADMIN' user
PGADMIN_PASS=blanksystem-db

# Port to expose PGADMIN to the host
PGADMIN_PORT=5013


# Kafka
KAFKA_VERSION=8.0.1

# Version of Kafka UI
KAFKA_UI_VERSION=0.26.0

# Port to expose Postgres to the host
KAFKA_UI_PORT=9080

# Port to expose Schema Registry to the host
SCHEMA_PORT=8081

# Port to expose Nodes to the host
KAFKA_1_PORT=9092
KAFKA_1_PORT=9093
KAFKA_1_PORT=9094

# SWAGGER
SWAGGER_UI_VERSION=v5.17.3
SWAGGER_UI_PORT=9081
SWAGGER_EDIT_PORT=9082
ASYNC_EDIT_PORT=9083

